FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      D;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 0 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    interface
    {
        type            solidTraction;
        traction        uniform (0 0 0);
        pressure        uniform 0;
        value           uniform (0 0 0);
    }

    gateTop
    {
        type            uniformFixedValue;

        uniformValue
        {
            type        table;
            values
            (
                (0.00    (0 0.00 0))
                (0.05    (0 0.01 0))
                (0.10    (0 0.02 0))
                (0.20    (0 0.04 0))
                (0.30    (0 0.06 0))
                (0.40    (0 0.08 0))
                (0.50    (0 0.10 0))
                (0.60    (0 0.12 0))
                (0.70    (0 0.14 0))
                (0.80    (0 0.16 0))
                (0.90    (0 0.18 0))
                (1.00    (0 0.20 0))
                (2.00    (0 0.20 0))
                (3.00    (0 0.20 0))
            );
        }

        value           uniform (0 0 0);
    }

    solidFrontAndBack
    {
        type            empty;
    }
}
// ************************************************************************* //
