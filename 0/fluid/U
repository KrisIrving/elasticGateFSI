FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    leftWall
    {
        type            noSlip;
    }

    bottomWall
    {
        type            noSlip;
    }

    rightOutlet
    {
        type            pressureInletOutletVelocity;
        value           uniform (0 0 0);
    }

    topAtmosphere
    {
        type            pressureInletOutletVelocity;
        value           uniform (0 0 0);
    }

    fluidGateLeft
    {
        type            noSlip;
    }

    fluidGateRight
    {
        type            noSlip;
    }

    fluidGateBottom
    {
        type            noSlip;
    }

    fluidGateTop
    {
        type            noSlip;
    }

    frontAndBack
    {
        type            empty;
    }
}

