FoamFile
{
    version     2.0;
    format      ascii;
    class       pointVectorField;
    object      pointMotionU;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    interface
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    leftWall
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    bottomWall
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    rightOutlet
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    topAtmosphere
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    fluidGateTop
    {
            type uniformFixedValue;
            uniformValue
            {
                type table;
                values
                (
                    (0.0    (0 0.01 0))
                    (1.0    (0 0.01 0))
                    (1.0001 (0 0.0 0))
                    (3.0    (0 0.0 0))
                );
            }
    }

    frontAndBack
    {
        type            empty;
    }
}
