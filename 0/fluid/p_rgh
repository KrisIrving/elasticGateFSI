FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p_rgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    leftWall
    {
        type            fixedFluxPressure;
        value           uniform 0;
    }

    bottomWall
    {
        type            fixedFluxPressure;
        value           uniform 0;
    }

    rightOutlet
    {
        type            totalPressure;
        p0              uniform 0;
        value           uniform 0;
    }

    topAtmosphere
    {
        type            totalPressure;
        p0              uniform 0;
        value           uniform 0;
    }

    fluidGateLeft
    {
        type            fixedFluxPressure;
        value           uniform 0;
    }

    fluidGateRight
    {
        type            fixedFluxPressure;
        value           uniform 0;
    }

    fluidGateBottom
    {
        type            fixedFluxPressure;
        value           uniform 0;
    }

    fluidGateTop
    {
        type            fixedFluxPressure;
        value           uniform 0;
    }

    frontAndBack
    {
        type            empty;
    }
}

