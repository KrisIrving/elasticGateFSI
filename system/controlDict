FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     solids4Foam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         1;

deltaT          1e-5;

writeControl    adjustableRunTime;

writeInterval   0.005;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable yes;

adjustTimeStep  yes;

maxCo           0.2;

maxDeltaT       1e-4;

maxAlphaCo      0.2;

functions
{
    gateTopDisplacement
    {
        type        solidPointDisplacement;
        point       (1.22 0.410 0.005);
    }

    gateMidDisplacement
    {
        type        solidPointDisplacement;
        point       (1.22 0.210 0.005);
    }

    gateBottomDisplacement
    {
        type        solidPointDisplacement;
        point       (1.22 0.010 0.005);
    }
}

