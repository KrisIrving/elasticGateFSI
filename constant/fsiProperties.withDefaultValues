FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       Aitken;
    location    "constant";
    object      fsiProperties.withDefaultValues;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

fluidSolidInterface Aitken;

AitkenCoeffs
{
    solidPatch      interface;
    fluidPatch      interface;
    relaxationFactor 0.2;
    interfaceDeformationLimit 0;
    outerCorrTolerance 1e-06;
    nOuterCorr      30;
    coupled         yes;
    additionalMeshCorrection false;
    couplingStartTime -1;
    predictor       false;
    incrementalResiduals true;
    writeResidualsToFile false;
    interpolatorUpdateFrequency 0;
    GGICoeffs
    {
    }
    AMICoeffs
    {
    }
    RBFCoeffs
    {
    }
    directMapCoeffs
    {
    }
    interfaceTransferMethod AMI;
    relaxationFactorMax 1;
    predictSolid    true;
}


